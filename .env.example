# ============================================
# SUPABASE
# -------- kaise len:
#   1. https://supabase.com/dashboard/account/tokens  →  "Generate Token" karo, name do, copy karo
#   2. https://supabase.com/dashboard/projects  →  apna project kholo
#      Settings → API  → copy karo: Project URL (NEXT_PUBLIC_SUPABASE_URL),
#      anon public key (NEXT_PUBLIC_SUPABASE_ANON_KEY), service_role secret (SUPABASE_SERVICE_ROLE_KEY)
#   3. Settings → Database → Connection string → "URI" copy karo (DATABASE_URL)
#      wahan "direct connection" alag hai — wo DIRECT_URL hai (port 5432 wala)
# ============================================
SUPABASE_PROJECT_REF=your_project_ref
SUPABASE_MGMT_TOKEN=sbp_your_supabase_management_token_here
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMjM0NTY3ODkwIiwibmFtZSI6IkpvaG4gRG9lIiwiaWF0IjoxNTE2MjM5MDIyfQ
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMjM0NTY3ODkwIiwicm9sZSI6InNlcnZpY2Vfcm9sZSJ9
DATABASE_URL=postgresql://postgres.your_ref:your_password@aws-1-region.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.your_ref:your_password@aws-1-region.pooler.supabase.com:5432/postgres

# ============================================
# VERCEL
# -------- kaise len:
#   1. https://vercel.com/account/tokens  →  "Create... Token" karo, name do
#      Scope = "Full Account" ya specific team, expiry = "No Expiry"
#      Copy token (vcp_... start hota hai)
# ============================================
VERCEL_TOKEN=vcp_your_vercel_api_token_here

# ============================================
# GITHUB
# -------- kaise len:
#   1. https://github.com/settings/tokens  → "Generate new token (classic)"
#   2. Scopes: repo (full control), workflow, admin:repo_hooks
#   3. Copy token (ghp_... start hota hai)
#   4. GITHUB_USERNAME = tumhara GitHub username (case sensitive)
#   5. GITHUB_REPO = repo name (pahle se GitHub par bana hua ho ya agent banayega)
# ============================================
GITHUB_USERNAME=your-github-username
GITHUB_TOKEN=ghp_your_github_personal_access_token
GITHUB_REPO=your-repo-name

# ============================================
# CLOUDFLARE
# -------- kaise len:
#   1. Zone ID: https://dash.cloudflare.com  → domain select karo
#      Right sidebar mein "Zone ID" likha hai — copy karo
#   2. API Token: https://dash.cloudflare.com/profile/api-tokens
#      → "Create Token" → "Edit zone DNS" template choose karo
#      Zone Resources: Include → apna domain
#      Copy token (cfut_... ya CFAPI_... start hota hai)
#   3. Account ID: dashboard URL mein /account-id/ wala hai ya
#      https://dash.cloudflare.com  → sidebar neeche "Account ID" likha hai
# ============================================
CLOUDFLARE_ZONE_ID=your_cloudflare_zone_id
CLOUDFLARE_API_TOKEN=cfut_your_cloudflare_api_token
CF_ACCOUNT_ID=your_cloudflare_account_id

# ============================================
# CACHE & WEBHOOK
# -------- kaise len:
#   REVALIDATE_SECRET: koi bhi random secret (32 chars) — agent bana dega
#   NEXT_PUBLIC_SITE_URL: local development ke liye http://localhost:3000
# ============================================
REVALIDATE_SECRET=your_random_secret_string_min_16_chars
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================
# SEO
# -------- kaise len:
#   GOOGLE_SITE_VERIFICATION: https://search.google.com/search-console  → "DNS TXT Record" se verify karo
#   INDEXNOW_API_KEY: https://www.indexnow.org/  → key generate karo
# ============================================
GOOGLE_SITE_VERIFICATION=google_your_verification_code
INDEXNOW_API_KEY=your_indexnow_api_key

# ============================================
# GOOGLE INDEXING API — Instant Google crawl
# -------- kaise len:
#   1. https://console.cloud.google.com/apis/library/indexing.googleapis.com → Enable
#   2. https://console.cloud.google.com/iam-admin/serviceaccounts → Create SA → JSON download
#   3. JSON file se client_email aur private_key nikal kar yahan daalo
#   4. https://search.google.com/search-console → Settings → Users → Add SA email as Owner
# IMPORTANT: private_key single-line hona chahiye with literal \n characters
# ============================================
GOOGLE_INDEXING_SA_EMAIL=your-sa@your-project.iam.gserviceaccount.com
GOOGLE_INDEXING_SA_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ============================================
# BRAND (Optional — DB settings se aayega)
# ============================================
NEXT_PUBLIC_BRAND_NAME=Your Store Name
NEXT_PUBLIC_TWITTER_HANDLE=@your_handle
NEXT_PUBLIC_ADMIN_EMAIL=admin@yourstore.com

# ============================================
# META (Facebook) CATALOG SYNC
# -------- kaise len:
#   META_CATALOG_ID: https://business.facebook.com/commerce/catalogs  → apna catalog kholo
#      URL mein "catalog_id=123456789" wala number
#   META_ACCESS_TOKEN: https://business.facebook.com  → Business Settings → System Users
#      → apna system user → "Generate Token" → permissions: catalog_management
#   NEXT_PUBLIC_META_PIXEL_ID: https://facebook.com/events_manager  → Data Sources → Pixel ID
# ============================================
META_CATALOG_ID=your_facebook_catalog_id
META_ACCESS_TOKEN=EAAT_your_facebook_access_token
META_GRAPH_API_VERSION=v21.0
NEXT_PUBLIC_META_PIXEL_ID=your_facebook_pixel_id

# ============================================
# CRON — Automates sitemap, cleanup, sync
# --------
#   CRON_SECRET: koi bhi secret string — Vercel Cron se match hona chahiye
# ============================================
CRON_SECRET=your_cron_secret_string

# ============================================
# PUSHER — Real-time traffic (optional)
# -------- kaise len:
#   1. https://dashboard.pusher.com  → sign up / login
#   2. "Create new app" → name do, cluster "ap2" for Asia
#   3. App Keys tab se copy karo: App ID, Key, Secret, Cluster
#   4. Frontend key = NEXT_PUBLIC_PUSHER_KEY, cluster = NEXT_PUBLIC_PUSHER_CLUSTER
#   5. Free tier: 200k msgs/day, 100 connections — enough for traffic
# ============================================
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=

# ============================================
# AI KEYS — Admin Panel mein set karo (NOT here)
# Groq, Gemini, Mistral, OpenRouter, DeepSeek, Cerebras
# → Admin Dashboard → Settings → AI Settings
# ============================================
